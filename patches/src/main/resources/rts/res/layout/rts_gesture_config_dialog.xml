<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#cc000000">
    <LinearLayout
        android:id="@+id/layout_dialog"
        android:orientation="vertical"
        android:layout_width="460dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:paddingBottom="16dp"
        android:background="@drawable/rts_dialog_background">
        <TextView
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="RTS Gesture Settings" />
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                    <CheckBox android:id="@+id/rts_gesture_tap_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tap" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Left Click" android:textSize="12sp" android:textColor="#ff888e99" />
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                    <CheckBox android:id="@+id/rts_gesture_long_press_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Long Press" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Right Click" android:textSize="12sp" android:textColor="#ff888e99" />
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                    <CheckBox android:id="@+id/rts_gesture_double_tap_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Double Tap" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Double Click" android:textSize="12sp" android:textColor="#ff888e99" />
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                    <CheckBox android:id="@+id/rts_gesture_drag_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Drag" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hold Left Click" android:textSize="12sp" android:textColor="#ff888e99" />
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                    <CheckBox android:id="@+id/rts_gesture_pinch_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pinch" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="8dp" />
                    <TextView android:id="@+id/rts_gesture_pinch_spinner" android:layout_width="120dp" android:layout_height="32dp" android:gravity="center" android:textSize="12sp" android:textColor="#ff888e99" android:clickable="true" android:background="#1affffff" android:paddingStart="12dp" android:paddingEnd="12dp" />
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="48dp" android:gravity="center_vertical">
                    <CheckBox android:id="@+id/rts_gesture_two_finger_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Two-Finger Drag" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="8dp" />
                    <TextView android:id="@+id/rts_gesture_two_finger_spinner" android:layout_width="120dp" android:layout_height="32dp" android:gravity="center" android:textSize="12sp" android:textColor="#ff888e99" android:clickable="true" android:background="#1affffff" android:paddingStart="12dp" android:paddingEnd="12dp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
        <Button
            android:id="@+id/tvClose"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="60dp"
            android:layout_marginEnd="60dp"
            android:text="Close"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
